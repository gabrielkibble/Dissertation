{
    "name": "practice_dbn",
    "model": {                                       
        "type": "DBN",
        "args": {                                       
            "n_visible": 51,
            "n_hidden": [128, 64],
            "n_classes": 7, 
            "learning_rate": [0.01, 0.01],
            "momentum": [0.9, 0.9],
            "decay": [0, 0],
            "batch_size": [128, 128],
            "num_epochs": [1, 1], 
            "k": [1, 1]
        }
    },
    "data_loader": {
        "type": "CICIDS2017DataLoader",                 
        "args": {
            "batch_size": 256,
            "balanced": false
        }
    },
    "optimizer": {
        "type": "Adam",
        "args": {
            "lr": 0.001,                                
            "weight_decay": 0,                          
            "amsgrad": false
        }
    },
    "loss": {
        "type": "CrossEntropyLoss",                     
        "args": {
            "reduction": "mean"
        }
    },
    "trainer": {
        "num_epochs": 1                                 
    }
}